<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Iconr</id>
    <version>1.0.0</version>
    <authors>benguru</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/benguru/iconr</projectUrl>
    <description>Lightweight icon library for Avalonia UI. Ships 1,500+ Phosphor icons as embedded SVGs with strongly-typed enum access, XAML markup extensions, and zero runtime dependencies beyond Avalonia.</description>
    <copyright>Copyright (c) 2026 benguru. Phosphor Icons Copyright (c) 2020 Phosphor Icons.</copyright>
    <tags>avalonia icons phosphor svg xaml ui desktop cross-platform</tags>
    <repository type="git" url="https://github.com/benguru/iconr" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Avalonia" version="12.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="/mnt/c/Dev/btemp/iconr/src/Iconr/bin/Release/net10.0/Iconr.dll" target="lib/net10.0/Iconr.dll" />
    <file src="/mnt/c/Dev/btemp/iconr/README.md" target="/README.md" />
    <file src="/mnt/c/Dev/btemp/iconr/LICENSE" target="/LICENSE" />
    <file src="/mnt/c/Dev/btemp/iconr/THIRD-PARTY-NOTICES.md" target="/THIRD-PARTY-NOTICES.md" />
  </files>
</package>